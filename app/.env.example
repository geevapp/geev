# Database Configuration
# DATABASE_URL (Mandatory): PostgreSQL connection string for Prisma.
DATABASE_URL=postgresql://geev:bridgelet_pass@localhost:5432/geev

# Authentication (NextAuth)
# AUTH_SECRET (Mandatory): Used by Auth.js to encrypt session cookies (can be any random 32+ char string).
AUTH_SECRET=your-random-32-character-secret
# NEXTAUTH_SECRET (Mandatory): Fallback for Auth.js, should match AUTH_SECRET.
NEXTAUTH_SECRET=your-random-32-character-secret

# AWS / File Uploads
# AWS_REGION (Optional): Region for AWS S3 bucket.
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID (Optional): AWS credentials for file uploads.
AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY (Optional): AWS credentials for file uploads.
AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET (Optional): S3 bucket name.
AWS_S3_BUCKET=your-bucket-name
# CDN_BASE_URL (Optional): CDN base URL for served assets.
CDN_BASE_URL=https://cdn.yourdomain.com 

# SEP-10 Stellar Web Authentication Configuration
# STELLAR_SERVER_SECRET (Mandatory): Server keypair for SEP-10 auth. Generate using https://laboratory.stellar.org/#account-creator?network=testnet
STELLAR_SERVER_SECRET=SBSW2XWCHXLQ4OZIQ2Q3TQ3DJC23LK3LQ3LQ3LQ3LQ3LQ3LQ3LQ3LQ3L
# STELLAR_NETWORK (Mandatory): The Stellar network to use (testnet or public).
STELLAR_NETWORK=testnet
# STELLAR_HORIZON_URL (Mandatory): Stellar Horizon API endpoint.
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# STELLAR_HOME_DOMAIN (Mandatory): Domain name used for SEP-10 authentication challenge.
STELLAR_HOME_DOMAIN=localhost:3000
# STELLAR_WEB_AUTH_DOMAIN (Mandatory): Web authentication domain for SEP-10 verification.
STELLAR_WEB_AUTH_DOMAIN=localhost:3000

# Soroban Indexer Configuration
# SOROBAN_RPC_URL (Mandatory): RPC endpoint for the Soroban smart contracts.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# GEEV_CONTRACT_ID (Mandatory): Address of the deployed Soroban contract.
GEEV_CONTRACT_ID=
# SOROBAN_NETWORK (Mandatory): Network for Soroban indexing (testnet or public).
SOROBAN_NETWORK=testnet
# INDEXER_POLL_INTERVAL_MS (Optional): Polling interval for indexing blockchain events.
INDEXER_POLL_INTERVAL_MS=5000

# Cron Configuration
# CRON_SECRET (Mandatory): Secret key used to secure cron API endpoints.
CRON_SECRET=your-cron-secret-key-here
